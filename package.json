{
  "name": "cohesion",
  "version": "1.2.0",
  "description": "A Notion Desktop client for Linux",
  "main": "dist/index.js",
  "scripts": {
    "dist": "tsc && cp src/*.html dist/ && cp -r src/js dist/",
    "watch": "tsc -w",
    "lint": "eslint -c .eslintrc --ext .ts ./src",
    "start": "npm run dist && electron .",
    "build": "npm version patch --no-git-tag-version && npm run dist && electron-builder",
    "build:extensions": "cd browser-extension && ./build.sh",
    "build:snap": "npm version patch --no-git-tag-version && npm run dist && electron-builder --linux snap",
    "build:deb": "npm version patch --no-git-tag-version && npm run dist && electron-builder --linux deb",
    "flatpak:init-tools": "git submodule update --init --recursive flatpak/flatpak-builder-tools",
    "preflatpak:generate-sources": "rm -rf node_modules && npm install --package-lock-only",
    "flatpak:generate-sources": "./flatpak/generate-sources.sh",
    "flatpak:lint": "",
    "flatpak:build": "flatpak-builder --force-clean --user --install-deps-from=flathub --repo=repo --install builddir flatpak/flathub-manifest/io.github.brunofin.Cohesion.yml"
  },
  "author": "Bruno Finger <bruno.k.finger@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "electron-store": "11.0.2"
  },
  "devDependencies": {
    "electron": "42.5.0",
    "electron-builder": "26.15.3",
    "typescript": "6.0.3"
  },
  "build": {
    "appId": "io.github.brunofin.Cohesion",
    "directories": {
      "output": "./build"
    },
    "files": [
      "dist",
      "package.json"
    ],
    "extraFiles": [
      "data"
    ],
    "linux": {
      "target": [
        "deb"
      ],
      "icon": "data/icons/hicolor/512x512/apps/io.github.brunofin.Cohesion.png",
      "category": "Office",
      "desktop": {
        "entry": {
          "Name": "Cohesion",
          "Comment": "An unofficial Notion client for Linux, built with Electron.",
          "Categories": "Office;Development;",
          "Keywords": "Notion;Notes;Text;Database;Sheets;",
          "MimeType": "x-scheme-handler/notion;"
        }
      }
    }
  }
}
